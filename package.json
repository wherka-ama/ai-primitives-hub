    "package:vsix": "pnpm -C apps/vscode-extension run package:vsix"
  },
  "devDependencies": {
    "@o3r/eslint-config": "^14.0.4",
    "eslint": "^9.0.0",
    "globals": "^16.5.0"
  }
}
