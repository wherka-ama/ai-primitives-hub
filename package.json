{
  "name": "ai-primitives-hub",
  "version": "0.0.2",
  "private": true,
  "description": "AI Primitives Hub monorepo workspace root",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "watch": "pnpm -r watch",
    "lint": "pnpm -r lint",
