// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm: watch",
      "type": "shell",
      "command": "pnpm run watch",
      "options": {
        "cwd": "${workspaceFolder}/apps/vscode-extension"
      },
      "problemMatcher": {
        "base": "$tsc-watch",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[webpack-cli\\] Compiler starting\\.\\.\\.",
          "endsPattern": "^\\[webpack-cli\\] Compiler finished"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "never",
        "group": "watchers"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "pnpm: watch-tests",
      "type": "shell",
      "command": "pnpm run watch-tests",
      "options": {
        "cwd": "${workspaceFolder}/apps/vscode-extension"
      },
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never",
        "group": "watchers"
      },
      "group": "build"
    },
    {
      "label": "tasks: watch-tests",
      "dependsOn": ["pnpm: watch", "pnpm: watch-tests"],
      "problemMatcher": []
    },
    {
      "label": "pnpm: compile",
      "type": "shell",
      "command": "pnpm run compile",
      "options": {
        "cwd": "${workspaceFolder}/apps/vscode-extension"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
